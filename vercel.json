{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/frontend/index.html" },
    { "source": "/assets/(.*)", "destination": "/frontend/assets/$1" },
    { "source": "/admin_login", "destination": "/frontend/admin_login.html" },
    { "source": "/official_login", "destination": "/frontend/official_login.html" },
    { "source": "/beneficiary", "destination": "/frontend/beneficiary.html" },
    { "source": "/beneficiary_register", "destination": "/frontend/beneficiary_register.html" },
    { "source": "/peso_officer", "destination": "/frontend/peso_officer.html" },
    { "source": "/peso_admin", "destination": "/frontend/peso_admin.html" },
    { "source": "/cswdo_officer", "destination": "/frontend/cswdo_officer.html" },
    { "source": "/cswdo_admin", "destination": "/frontend/cswdo_admin.html" },
    { "source": "/evaluator", "destination": "/frontend/evaluator.html" },
    { "source": "/(.*)\\.html", "destination": "/frontend/$1.html" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
